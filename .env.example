# ========================================
# 智解法链 (ZJFL) 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ========================================

# 应用配置
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置 (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=zjfl_db
DB_USER=zjfl_user
DB_PASSWORD=zjfl_password_change_me
DATABASE_URL=postgresql+asyncpg://zjfl_user:zjfl_password_change_me@postgres:5432/zjfl_db

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me
REDIS_DB=0

# JWT 配置
JWT_SECRET_KEY=jwt-secret-key-change-in-production-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# 邮件配置 (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@zjfl.com
SMTP_PASSWORD=smtp_password
SMTP_FROM_NAME=智解法链
SMTP_TLS=true

# 阿里云短信配置 (可选)
ALIYUN_SMS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=智解法链
ALIYUN_SMS_TEMPLATE_CODE=SMS_000000

# 文件存储配置 (对象存储 OSS)
# 本地开发使用 local，生产使用 oss
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/uploads
OSS_ACCESS_KEY_ID=your_oss_access_key
OSS_ACCESS_KEY_SECRET=your_oss_secret
OSS_BUCKET_NAME=zjfl-files
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# 声网 Agora 视频会议配置 (Mock模式可留空)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate
AGORA_ENABLE_MOCK=true

# 存证服务配置 (Mock模式可留空)
TIMESTAMP_SERVICE_PROVIDER=mock
TIMESTAMP_API_URL=https://api.timestampservice.com
TIMESTAMP_API_KEY=your_timestamp_api_key

# 电子签章配置 (法大大/e签宝, Mock模式)
ESIGN_PROVIDER=mock
ESIGN_API_URL=https://api.esign.com
ESIGN_APP_ID=your_esign_app_id
ESIGN_APP_SECRET=your_esign_app_secret

# 演示模式 (true: 企业注册无需审核, false: 需要管理员审核)
DEMO_MODE=true

# 前端配置
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# 加密配置 (敏感字段AES加密)
AES_KEY=aes-key-32-chars-change-in-prod!!

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 文件上传限制
MAX_FILE_SIZE_MB=50
MAX_BATCH_UPLOAD=10

# 管理员默认账号 (首次初始化)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@zjfl.com
ADMIN_PASSWORD=admin123
